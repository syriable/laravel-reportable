{
    "name": "syriable/laravel-reportable",
    "description": "A generic reporting & moderation tracking system for Laravel. Make any model reportable, track moderation decisions and actions with a full audit history.",
    "keywords": [
        "syriable",
        "laravel",
        "laravel-reportable",
        "reports",
        "reporting",
        "moderation",
        "flagging",
        "abuse"
    ],
    "homepage": "https://github.com/syriable/laravel-reportable",
    "license": "MIT",
    "authors": [
        {
            "name": "Syriable",
            "email": "alkhatib.syr@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0||^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^2.9||^3.0",
        "orchestra/testbench": "^8.22||^9.0||^10.0",
        "pestphp/pest": "^2.34||^3.0",
        "pestphp/pest-plugin-laravel": "^2.3||^3.0"
    },
    "suggest": {
        "spatie/laravel-activitylog": "Automatically write report lifecycle entries to the activity log."
    },
    "autoload": {
        "psr-4": {
            "Syriable\\Reportable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syriable\\Reportable\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Syriable\\Reportable\\ReportableServiceProvider"
            ],
            "aliases": {
                "Reportable": "Syriable\\Reportable\\Facades\\Reportable"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
